# --- Perfil de execução ---
# dev: segredos opcionais (útil para desenvolvimento local)
# prod: segredos abaixo são obrigatórios; boot falha sem eles
PROFILE=dev

# --- Logging ---
# Níveis válidos: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Segredos ---
# Em produção, preferir armazenar no keyring nativo do SO:
#   macOS (Keychain):
#     security add-generic-password -s consigaz-robo -a openai_api_key -w 'sk-...'
#   Windows (Credential Manager):
#     cmdkey /generic:consigaz-robo /user:openai_api_key /pass:sk-...
#
# O keyring tem precedência sobre este arquivo. Manter aqui apenas
# para desenvolvimento local — nunca commitar .env real.

OPENAI_API_KEY=
DESKTOP_APP_PASSWORD=
WEB_PLATFORM_PASSWORD=
